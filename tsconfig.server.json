{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {},
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "outDir": ".server-dist",
    "rootDir": "."
  },
  "include": [
    "server.ts",
    "worker.ts",
    "databasePrepare.ts",
    "server/**/*.ts",
    "scripts/**/*.ts"
  ]
}
