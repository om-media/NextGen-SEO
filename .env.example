# APP_BASE_URL: The public origin where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_BASE_URL="http://localhost:3000"

# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET:
# Required for persistent Google Search Console + GA4 access.
# Create a Google OAuth Web Application client and point its redirect URI to:
#   http://localhost:3000/api/google/oauth/callback
# or your deployed app URL equivalent.
GOOGLE_OAUTH_CLIENT_ID="MY_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="MY_GOOGLE_OAUTH_CLIENT_SECRET"

# Required production overrides:
# - NODE_ENV=production enables startup validation.
# - APP_BASE_URL must be your public https:// origin.
# - GOOGLE_OAUTH_STATE_SECRET and GOOGLE_TOKEN_ENCRYPTION_KEY must each be
#   strong random values with at least 32 characters.
NODE_ENV="development"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/oauth/callback"
GOOGLE_OAUTH_STATE_SECRET="CHANGE_ME"
GOOGLE_TOKEN_ENCRYPTION_KEY="CHANGE_ME_TOO"

# Database:
# Leave DATABASE_URL empty to keep using the local sqlite.db fallback during development.
# DATABASE_URL is required when NODE_ENV=production.
# Set it to a PostgreSQL connection string to run the app on Postgres.
# Local Postgres compose example:
#   npm run db:postgres:up
#   DATABASE_URL="postgresql://nextgen_seo:nextgen_seo_dev_password@localhost:5432/nextgen_seo"
DATABASE_URL=""
POSTGRES_SSL="false"

# Built-in BGE-M3 worker:
# Started automatically by npm run dev through the local Docker stack.
# The model is downloaded once into a persistent Docker volume.
INTERNAL_LINK_EMBEDDING_WORKER_URL="http://127.0.0.1:8091"
INTERNAL_LINK_BUILT_IN_MODEL="BAAI/bge-m3"

# Optional Ollama endpoint. Only used when the Ollama provider is selected.
INTERNAL_LINK_OLLAMA_BASE_URL="http://127.0.0.1:11434"

# Optional billing URLs for upgrade and portal flows.
# These can point to Stripe Checkout / Billing Portal later, or to any hosted billing pages.
BILLING_CHECKOUT_URL_PRO="https://example.com/billing/checkout/pro"
BILLING_CHECKOUT_URL_ENTERPRISE="https://example.com/billing/contact/enterprise"
BILLING_PORTAL_URL="https://example.com/billing/portal"
BILLING_WEBHOOK_SECRET="CHANGE_ME_WEBHOOK_SECRET"
