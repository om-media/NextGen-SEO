# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET:
# Required for persistent Google Search Console + GA4 access.
# Create a Google OAuth Web Application client and point its redirect URI to:
#   http://localhost:3000/api/google/oauth/callback
# or your deployed app URL equivalent.
GOOGLE_OAUTH_CLIENT_ID="MY_GOOGLE_OAUTH_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="MY_GOOGLE_OAUTH_CLIENT_SECRET"

# Optional overrides for production or reverse-proxy setups.
APP_BASE_URL="http://localhost:3000"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/google/oauth/callback"
GOOGLE_OAUTH_STATE_SECRET="CHANGE_ME"
GOOGLE_TOKEN_ENCRYPTION_KEY="CHANGE_ME_TOO"

# Optional billing URLs for upgrade and portal flows.
# These can point to Stripe Checkout / Billing Portal later, or to any hosted billing pages.
BILLING_CHECKOUT_URL_PRO="https://example.com/billing/checkout/pro"
BILLING_CHECKOUT_URL_ENTERPRISE="https://example.com/billing/contact/enterprise"
BILLING_PORTAL_URL="https://example.com/billing/portal"
BILLING_WEBHOOK_SECRET="CHANGE_ME_WEBHOOK_SECRET"
