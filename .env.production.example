# Copy this file to your deployment platform's secret/environment settings.
# Do not commit real production values.

NODE_ENV="production"
PORT="3000"

# Public HTTPS origin and OAuth callback URL.
APP_BASE_URL="https://your-app.example.com"
GOOGLE_OAUTH_REDIRECT_URI="https://your-app.example.com/api/google/oauth/callback"

# PostgreSQL must be reachable from the production runtime.
DATABASE_URL="postgresql://gscplus:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/gscplus"
POSTGRES_DB="gscplus"
POSTGRES_USER="gscplus"
POSTGRES_PASSWORD="CHANGE_ME_DATABASE_PASSWORD"
POSTGRES_SSL="false"

# Generate strong values with: npm run secrets:generate
GOOGLE_OAUTH_STATE_SECRET="CHANGE_ME_GENERATE_WITH_NPM_RUN_SECRETS"
GOOGLE_TOKEN_ENCRYPTION_KEY="CHANGE_ME_GENERATE_WITH_NPM_RUN_SECRETS"

# Google integrations.
GOOGLE_OAUTH_CLIENT_ID="CHANGE_ME_GOOGLE_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="CHANGE_ME_GOOGLE_CLIENT_SECRET"

# Runtime capacity. Scale worker containers independently after load testing.
WEB_REPLICAS="2"
CRAWL_JOB_CONCURRENCY="2"
INTERNAL_LINK_JOB_CONCURRENCY="2"
INTERNAL_LINK_LOCK_TIMEOUT_MS="600000"
POSTGRES_POOL_MAX="20"
WEB_POSTGRES_POOL_MAX="15"
CRAWL_POSTGRES_POOL_MAX="8"
INTERNAL_LINK_POSTGRES_POOL_MAX="10"
WAREHOUSE_POSTGRES_POOL_MAX="8"
SCHEDULER_POSTGRES_POOL_MAX="4"
PREPARE_POSTGRES_POOL_MAX="4"
POSTGRES_IDLE_TIMEOUT_MS="30000"
POSTGRES_CONNECTION_TIMEOUT_MS="10000"
POSTGRES_STATEMENT_TIMEOUT_MS="120000"

# Managed BGE-M3 service.
INTERNAL_LINK_EMBEDDING_WORKER_URL="http://embedding-worker:8091"
EMBEDDING_DEVICE="cpu"
EMBEDDING_BATCH_SIZE="32"
EMBEDDING_MAX_BATCH_SIZE="128"
EMBEDDING_MAX_QUEUE_REQUESTS="128"
EMBEDDING_MAX_QUEUE_TEXTS="4096"
EMBEDDING_QUEUE_TIMEOUT_MS="300000"
