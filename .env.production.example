# Copy this file to your deployment platform's secret/environment settings.
# Do not commit real production values.

NODE_ENV="production"
PORT="3000"

# Public HTTPS origin and OAuth callback URL.
APP_BASE_URL="https://your-app.example.com"
GOOGLE_OAUTH_REDIRECT_URI="https://your-app.example.com/api/google/oauth/callback"

# PostgreSQL must be reachable from the production runtime.
DATABASE_URL="postgresql://user:password@host:5432/database"
POSTGRES_SSL="true"

# Generate strong values with: npm run secrets:generate
GOOGLE_OAUTH_STATE_SECRET="CHANGE_ME_GENERATE_WITH_NPM_RUN_SECRETS"
GOOGLE_TOKEN_ENCRYPTION_KEY="CHANGE_ME_GENERATE_WITH_NPM_RUN_SECRETS"

# Google integrations.
GOOGLE_OAUTH_CLIENT_ID="CHANGE_ME_GOOGLE_CLIENT_ID"
GOOGLE_OAUTH_CLIENT_SECRET="CHANGE_ME_GOOGLE_CLIENT_SECRET"

# Optional billing.
BILLING_CHECKOUT_URL_PRO="https://example.com/billing/checkout/pro"
BILLING_CHECKOUT_URL_ENTERPRISE="https://example.com/billing/contact/enterprise"
BILLING_PORTAL_URL="https://example.com/billing/portal"
BILLING_WEBHOOK_SECRET="CHANGE_ME_BILLING_WEBHOOK_SECRET"
