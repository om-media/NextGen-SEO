{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build:server && node .server-dist/server.js",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); for (const dir of ['dist','.server-dist']) fs.rmSync(dir, { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "guard:public-files": "node scripts/check-public-files.mjs --tracked",
    "verify": "npm run guard:public-files && npm run lint && npm run audit:prod && npm run build",
    "verify:docker": "node scripts/verify-docker-smoke.mjs",
    "verify:production-url": "node scripts/verify-production-url.mjs",
    "secrets:generate": "node scripts/generate-production-secrets.mjs",
    "db:postgres:up": "docker compose -f docker-compose.postgres.yml up -d",
    "db:postgres:down": "docker compose -f docker-compose.postgres.yml down",
    "db:migrate:postgres": "tsx --tsconfig tsconfig.server.json scripts/migrate-sqlite-to-postgres.ts",
    "benchmark:warehouse:pages": "tsx --tsconfig tsconfig.server.json scripts/benchmark-warehouse-pages.ts",
    "start": "node .server-dist/server.js"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "puppeteer": "^24.41.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
