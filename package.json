{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run local:services:up && npm run build && node .server-dist/server.js",
    "dev:vite": "npm run local:services:up && npm run build:server && node .server-dist/server.js",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs'); for (const dir of ['dist','.server-dist']) fs.rmSync(dir, { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "guard:public-files": "node scripts/check-public-files.mjs --tracked",
    "verify": "npm run guard:public-files && npm run lint && npm run check:warehouse-backfill && npm run check:warehouse-source-errors && npm run check:warehouse-job-leases && npm run check:gsc-summaries && npm run check:bing-query-dedupe && npm run check:bing-query-facts && npm run check:internal-link-quality && npm run check:crawl-worker-claims && npm run check:crawl-canonical-orphans && npm run check:internal-link-worker-claims && npm run check:postgres-hardening && npm run check:load-harness && npm run check:ga4-warehouse && npm run check:gsc-analytical-workflows && npm run check:warehouse-daily-lifecycle && npm run check:warehouse-route-lifecycle && npm run check:selector-stability && npm run check:workspace-defaults && npm run audit:prod && npm run build && npm run check:runtime-roles",
    "verify:docker": "node scripts/verify-docker-smoke.mjs",
    "verify:production-url": "node scripts/verify-production-url.mjs",
    "secrets:generate": "node scripts/generate-production-secrets.mjs",
    "local:services:up": "docker compose -f docker-compose.postgres.yml up -d --build",
    "local:services:down": "docker compose -f docker-compose.postgres.yml down",
    "db:postgres:up": "docker compose -f docker-compose.postgres.yml up -d postgres",
    "db:postgres:down": "docker compose -f docker-compose.postgres.yml stop postgres",
    "db:migrate:postgres": "tsx --tsconfig tsconfig.server.json scripts/migrate-sqlite-to-postgres.ts",
    "db:prepare": "node .server-dist/databasePrepare.js",
    "db:backfill:gsc-summaries": "tsx --tsconfig tsconfig.server.json scripts/backfill-gsc-monthly-summaries.ts",
    "benchmark:warehouse:pages": "tsx --tsconfig tsconfig.server.json scripts/benchmark-warehouse-pages.ts",
    "start": "node .server-dist/server.js",
    "start:web": "node .server-dist/server.js",
    "start:worker:crawl": "node .server-dist/worker.js crawl",
    "start:worker:internal-links": "node .server-dist/worker.js internal-links",
    "start:worker:warehouse": "node .server-dist/worker.js warehouse",
    "start:scheduler": "node .server-dist/worker.js scheduler",
    "check:warehouse-backfill": "tsx --tsconfig tsconfig.server.json scripts/check-warehouse-backfill-dedupe.ts",
    "check:warehouse-source-errors": "node scripts/check-warehouse-source-errors.mjs",
    "check:gsc-summaries": "tsx --tsconfig tsconfig.server.json scripts/check-gsc-monthly-summary-warmup.ts",
    "check:ga4-warehouse": "node scripts/check-ga4-warehouse-first.mjs",
    "check:gsc-analytical-workflows": "node scripts/check-gsc-analytical-workflows.mjs",
    "check:warehouse-daily-lifecycle": "tsx --tsconfig tsconfig.server.json scripts/check-warehouse-daily-lifecycle.ts",
    "check:warehouse-route-lifecycle": "tsx --tsconfig tsconfig.server.json scripts/check-warehouse-route-lifecycle.ts",
    "check:selector-stability": "node scripts/check-selector-stability.mjs",
    "check:workspace-defaults": "node scripts/check-workspace-defaults.mjs",
    "check:bing-query-dedupe": "tsx --tsconfig tsconfig.server.json scripts/check-bing-query-dedupe.ts",
    "check:internal-link-quality": "node scripts/check-internal-link-quality-fixtures.mjs",
    "check:internal-link-browser-smoke": "node scripts/check-internal-link-browser-smoke.mjs",
    "check:browser-acceptance": "node scripts/check-browser-acceptance.mjs",
    "check:queue-browser-smoke": "node scripts/check-queue-browser-smoke.mjs",
    "check:internal-link-pgvector": "node scripts/check-internal-link-pgvector.mjs",
    "check:internal-link-api-smoke": "node scripts/check-internal-link-api-smoke.mjs",
    "check:internal-link-embedding-worker": "node scripts/check-internal-link-embedding-worker.mjs",
    "check:internal-link-embedding-load": "node scripts/check-internal-link-embedding-load.mjs",
    "check:runtime-roles": "npm run build:server && node scripts/check-runtime-roles.mjs",
    "check:crawl-worker-claims": "tsx --tsconfig tsconfig.server.json scripts/check-crawl-worker-claims.ts",
    "check:crawl-canonical-orphans": "tsx --tsconfig tsconfig.server.json scripts/check-crawl-canonical-orphans.ts",
    "check:internal-link-worker-claims": "tsx --tsconfig tsconfig.server.json scripts/check-internal-link-worker-claims.ts",
    "check:postgres-hardening": "tsx --tsconfig tsconfig.server.json scripts/check-postgres-hardening.ts",
    "check:postgres-recovery": "node scripts/check-postgres-connection-recovery.mjs",
    "check:load-harness": "node scripts/load/check-load-harness.mjs",
    "load:production": "node scripts/load/run-production-load.mjs",
    "load:fixtures": "node scripts/load/prepare-local-fixtures.mjs",
    "check:bing-query-facts": "tsx --tsconfig tsconfig.server.json scripts/check-bing-query-facts.ts",
    "check:warehouse-job-leases": "tsx --tsconfig tsconfig.server.json scripts/check-warehouse-job-leases.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "puppeteer": "^24.41.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "undici": "7.28.0"
  }
}
