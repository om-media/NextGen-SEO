{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing tier and unlocked sites.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User's email address."
        },
        "tier": {
          "type": "string",
          "enum": ["free", "pro", "enterprise"],
          "description": "The user's subscription tier."
        },
        "unlockedSites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of GSC site URLs the user has unlocked."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["email", "tier", "unlockedSites", "createdAt"]
    },
    "Project": {
      "title": "Project",
      "description": "An SEO project tracking a specific domain or property.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the project."
        },
        "domain": {
          "type": "string",
          "description": "The domain being tracked."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns the project."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "domain", "ownerId", "createdAt"]
    },
    "Filter": {
      "title": "Filter",
      "description": "A saved custom filter for GSC data.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the saved filter."
        },
        "projectId": {
          "type": "string",
          "description": "The ID of the project this filter belongs to."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who created the filter."
        },
        "configuration": {
          "type": "string",
          "description": "JSON stringified filter configuration."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "projectId", "ownerId", "configuration", "createdAt"]
    },
    "PageDailyStats": {
      "title": "PageDailyStats",
      "description": "Warehoused daily stats for a specific page, including query counts.",
      "type": "object",
      "properties": {
        "siteUrl": {
          "type": "string",
          "description": "The GSC site URL."
        },
        "date": {
          "type": "string",
          "description": "The date of the stats (YYYY-MM-DD)."
        },
        "page": {
          "type": "string",
          "description": "The page URL."
        },
        "queryCount": {
          "type": "number",
          "description": "The number of unique queries this page ranked for on this date."
        },
        "clicks": {
          "type": "number",
          "description": "Total clicks for this page on this date."
        },
        "impressions": {
          "type": "number",
          "description": "Total impressions for this page on this date."
        },
        "ownerId": {
          "type": "string",
          "description": "The UID of the user who owns this data."
        }
      },
      "required": ["siteUrl", "date", "page", "queryCount", "clicks", "impressions", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles including their tier and unlocked sites."
    },
    "/projects/{projectId}": {
      "schema": {
        "$ref": "#/entities/Project"
      },
      "description": "Stores SEO projects."
    },
    "/filters/{filterId}": {
      "schema": {
        "$ref": "#/entities/Filter"
      },
      "description": "Stores saved custom filters."
    },
    "/pageDailyStats/{statId}": {
      "schema": {
        "$ref": "#/entities/PageDailyStats"
      },
      "description": "Stores warehoused daily page stats."
    }
  }
}
